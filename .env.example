# ─── Piotet Memorial — environment ───────────────────────────────────────────
# Copy to server/.env for local dev. On DigitalOcean these are set as App-level
# env vars / bindable variables (see .do/app.yaml) — do NOT commit real values.

# --- API server ---
PORT=3001
NODE_ENV=development

# Comma-separated origins allowed to call the API (the static site's URL).
# In production DO fills this via ${_self.PUBLIC_URL}.
ALLOWED_ORIGINS=http://localhost:5173

# --- Postgres (tributes + moderation) ---
# DO injects DATABASE_URL automatically when a managed DB is attached.
DATABASE_URL=postgres://user:pass@localhost:5432/piotet

# --- Admin (tribute moderation) ---
# Simple shared secret guarding the /api/admin/* moderation endpoints.
# Generate a long random value; set as an encrypted secret on DO.
ADMIN_TOKEN=change-me-to-a-long-random-string

# --- Media (DigitalOcean Spaces + CDN) ---
# Public CDN base for family-curated audio/photos/video. The app references
# media by relative key (e.g. songs/001.mp3) and prefixes this base at runtime,
# so real files can be dropped into Spaces without a code change.
MEDIA_CDN_BASE=https://piotet-memorial.nyc3.cdn.digitaloceanspaces.com
